{
  "name": "kadaclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rspack serve --host 127.0.0.1 --port 1420",
    "build": "tsc && rspack build",
    "preview": "rspack serve --mode production --host 127.0.0.1 --port 1420",
    "postinstall": "node scripts/patch_typescript_plugin_css_modules.mjs",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "icons:generate": "python3 scripts/generate_icons.py",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build--no-sign": "yarn tauri:build -- --no-sign",
    "check": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "check:smoke": "bash scripts/smoke_check.sh"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@ant-design/x": "^2.5.0",
    "@tauri-apps/api": "^2.3.0",
    "antd": "^6.3.4",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.20",
    "dompurify": "^3.3.3",
    "marked": "^16.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@rspack/cli": "^1.2.8",
    "@rspack/core": "^1.2.8",
    "@rspack/plugin-react-refresh": "^1.6.1",
    "@tauri-apps/cli": "^2.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "webpack-dev-server": "^5.2.0"
  },
  "packageManager": "yarn@1.22.19"
}

{
  "name": "kadaclaw",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "rspack serve --host 127.0.0.1 --port 1420",
    "build": "tsc && rspack build",
    "preview": "rspack serve --mode production --host 127.0.0.1 --port 1420",
    "icons:generate": "python3 scripts/generate_icons.py",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build--no-sign": "npm run tauri:build -- --no-sign",
    "check": "tsc --noEmit && cargo check --manifest-path src-tauri/Cargo.toml",
    "check:smoke": "bash scripts/smoke_check.sh"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tauri-apps/api": "^2.3.0",
    "antd": "^6.3.4",
    "dayjs": "^1.11.20",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@rspack/cli": "^1.2.8",
    "@rspack/core": "^1.2.8",
    "@rspack/plugin-react-refresh": "^1.6.1",
    "@tauri-apps/cli": "^2.3.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.2",
    "webpack-dev-server": "^5.2.0"
  }
}

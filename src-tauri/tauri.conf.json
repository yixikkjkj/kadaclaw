{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kadaclaw",
  "version": "0.1.0",
  "identifier": "com.kadaclaw.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "titleBarStyle": "Overlay",
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
